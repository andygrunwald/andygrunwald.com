---
import { Image } from "astro:assets";
import { resolvePostImage } from "../scripts/post-images.js";

export interface Props {
  path: string;
  alt: string;
  title: string;
}

const { path, alt, title } = Astro.props;
const src = await resolvePostImage(path);
if (!src) {
  throw new Error(`BlogPostImage: no optimized image found for "${path}"`);
}
---

<div class="mb-10">
  <Image {src} {alt} {title} layout="constrained" class="rounded-lg" />
</div>
