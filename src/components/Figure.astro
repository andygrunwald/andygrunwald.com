---
import { Image } from "astro:assets";
import { resolvePostImage } from "../scripts/post-images.js";

export interface Props {
  path: string;
  title: string;
  alt: string;
  link?: string;
}

const { path, title, alt, link } = Astro.props;
const src = await resolvePostImage(path);
if (!src) {
  throw new Error(`Figure: no optimized image found for "${path}"`);
}
---

<div class="mb-10">
  <figure>
    {
      link ? (
        <a href={link}>
          <Image {src} {alt} {title} layout="constrained" class="rounded-lg" />
        </a>
      ) : (
        <Image {src} {alt} {title} layout="constrained" class="rounded-lg" />
      )
    }
    <figcaption>
      {title}
    </figcaption>
  </figure>
</div>
